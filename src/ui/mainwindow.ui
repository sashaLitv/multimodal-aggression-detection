             <property name="styleSheet">
              <string notr="true">/* --- АКТИВНИЙ СТАН (Синій) --- */
QPushButton {
    background-color: #0c2461; /* Темно-синій */
    color: white;
    border-radius: 12px;
    font-weight: bold;
    font-family: &quot;Arial&quot;;
    border: 2px solid transparent; /* Прозора рамка, щоб розмір не скакав */
}

/* При наведенні */
QPushButton:hover {
    background-color: #1e3799; /* Світліший синій */
}

/* При натисканні */
QPushButton:pressed {
    background-color: #0a1a3c; /* Дуже темний */
}

/* --- ЗАБЛОКОВАНИЙ СТАН (Ваш запит) --- */
QPushButton:disabled {
    background-color: #2f3640;  /* Темно-сірий фон */
    color: #7f8c8d;             /* Тьмяний текст */
    
    /* !!! ЯСКРАВЕ ПОМАРАНЧЕВЕ ОБВЕДЕННЯ !!! */
    border: 2px solid #e67e22;  
    border-style: dashed;       /* Пунктирна лінія для ефекту &quot;Зона заборонена&quot; */
}</string>
             </property>
             <property name="text">
              <string>ОБРАТИ ФАЙЛ ДЛЯ АНАЛІЗУ</string>
             </property>
